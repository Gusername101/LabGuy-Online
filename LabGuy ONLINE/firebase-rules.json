{
  "rules": {
    // ── Users ──────────────────────────────────────────────
    // Each user can read/write their own profile.
    // Admins can read all profiles.
    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    // ── Notifications ──────────────────────────────────────
    // A user can only read/write notifications addressed to them.
    "notifications": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "auth != null"
      }
    },

    // ── Dashboards ─────────────────────────────────────────
    // Each user owns their own widget layout.
    "dashboards": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },

    // ── Admin Requests ────────────────────────────────────
    // Any logged-in user can create a request.
    // Only admins/devs can read and delete them.
    "adminRequests": {
      ".read": "root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'developer'",
      ".write": "auth != null",
      ".indexOn": ["uid"],
      "$reqId": {
        ".read": "data.child('uid').val() === auth.uid"
      }
    },

    // ── System (developer-only) ───────────────────────────
    // maintenance flag: anyone can read, nobody can write via app
    // Set manually in Firebase console only
    "system": {
      ".read": "auth != null",
      ".write": "false"
    },

    // ── Labs ───────────────────────────────────────────────
    // Authenticated users can read labs.
    // Only admins can create/modify labs.
    "labs": {
      ".read":  "auth != null",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'",

      "$labId": {
        // Samples: any authenticated user can read/write
        "samples": {
          ".read":  "auth != null",
          ".write": "auth != null"
        },
        // Inventory: any authenticated user can read/write
        "inventory": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}
